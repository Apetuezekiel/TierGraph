{
	"name": "tiergraph",
	"version": "0.1.0",
	"description": "Zero-runtime-dependency TypeScript library for SaaS tier-based feature gating",
	"license": "MIT",
	"author": "Ezekiel Apetu",
	"repository": {
		"type": "git",
		"url": "https://github.com/Apetuezekiel/TierGraph.git"
	},
	"bugs": {
		"url": "https://github.com/Apetuezekiel/TierGraph/issues"
	},
	"homepage": "https://github.com/Apetuezekiel/TierGraph#readme",
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist/index.js",
		"dist/index.cjs",
		"dist/index.d.ts",
		"dist/index.d.cts",
		"schema",
		"README.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --coverage",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"schema:generate": "ts-json-schema-generator --path src/types.ts --type ConfigInput --out schema/config.schema.json",
		"prepublishOnly": "npm run typecheck && npm run test && npm run build"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@vitest/coverage-v8": "^3.1.3",
		"ts-json-schema-generator": "^2.9.0",
		"tsup": "^8.4.0",
		"typescript": "^5.8.3",
		"vitest": "^3.1.3"
	}
}
